PORT=3001

# 0 = 连接 MySQL；1 = mock，不连数据库
USE_MOCK_DB=0

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=secret
MYSQL_DATABASE=property_cost_control

# 需要 SSL 时设为 1（如部分云 RDS）
MYSQL_SSL=0

# 连接超时（毫秒）
# MYSQL_CONNECT_TIMEOUT_MS=30000

# 连接池大小
# MYSQL_POOL_SIZE=10

# 首次启动时若不存在则创建该登录用户
SEED_USERNAME=limingwen
SEED_PASSWORD=limingwen

JWT_SECRET=please_change_me
JWT_EXPIRES_IN=7d
